{
  "name": "flux-finances",
  "version": "0.0.1",
  "description": "",
  "workspaces": [
    "apps/*",
    "packages/**/*"
  ],
  "scripts": {
    "build": "turbo build",
    "lint": "biome lint --write",
    "format": "biome format --write",
    "check": "biome check --write",
    "dev": "turbo dev",
    "dev:app": "turbo dev --filter=app",
    "dev:marketing": "turbo dev --filter=marketing",
    "test": "turbo test",
    "clean": "pnpm --recursive --parallel exec rm -rf node_modules dist .turbo",
    "db:generate": "pnpm --filter=@flux/db db:generate",
    "db:migrate": "pnpm --filter=@flux/db db:migrate",
    "db:push": "pnpm --filter=@flux/db db:push"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.10",
    "turbo": "^2.7.1",
    "typescript": "^5.9.3"
  },
  "keywords": [],
  "author": "",
  "packageManager": "pnpm@10.26.1"
}
