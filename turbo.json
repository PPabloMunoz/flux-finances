{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "public/**", "*.config.*", "package.json"],
      "outputs": ["dist/**", ".astro/**"]
    },
    "lint": {
      "dependsOn": [],
      "inputs": ["src/**", "*.config.*", "package.json"]
    },
    "format": {
      "dependsOn": [],
      "inputs": ["src/**", "*.config.*", "package.json"]
    },
    "check": {
      "dependsOn": ["format", "lint"],
      "inputs": ["src/**", "*.config.*", "package.json"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["build"],
      "inputs": ["src/**", "test/**", "*.config.*", "package.json"],
      "outputs": ["coverage/**"]
    }
  },
  "globalDependencies": ["turbo.json"]
}
